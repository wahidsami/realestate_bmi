{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "dev:api": "npm run dev --workspace=@bina/api",
    "dev:full": "powershell -ExecutionPolicy Bypass -File .\\scripts\\dev.ps1",
    "build": "vite build",
    "build:api": "npm run build --workspace=@bina/api",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
