generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
  DELETED
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  WON
  LOST
}

enum InquiryStatus {
  NEW
  CONTACTED
  CLOSED
}

enum PageStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum TemplateStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum MediaType {
  IMAGE
  VIDEO
  DOCUMENT
  FLOORPLAN
  AVATAR
  SEO
  GALLERY
  OTHER
}

enum MediaVariantType {
  THUMBNAIL
  MEDIUM
  LARGE
  WEB
}

enum NotificationStatus {
  UNREAD
  READ
  ARCHIVED
}

enum SessionDeviceType {
  DESKTOP
  MOBILE
  TABLET
  BOT
  UNKNOWN
}

enum TokenType {
  REFRESH
  PASSWORD_RESET
}

model User {
  id           String      @id @default(cuid())
  email        String      @unique
  username     String      @unique
  passwordHash String
  firstName    String
  lastName     String
  fullName     String
  phone        String?
  avatar       String?
  jobTitle     String?
  department   String?
  isActive     Boolean     @default(true)
  isEmailVerified Boolean  @default(false)
  isPhoneVerified Boolean  @default(false)
  status       UserStatus  @default(ACTIVE)
  failedLoginAttempts Int   @default(0)
  lockedUntil  DateTime?
  passwordChangedAt DateTime?
  lastLoginAt  DateTime?
  metadata     Json?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  deletedAt    DateTime?

  createdById String?
  updatedById String?
  deletedById String?

  createdBy User? @relation("UserCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User? @relation("UserUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  deletedBy User? @relation("UserDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)

  createdUsers User[] @relation("UserCreatedBy")
  updatedUsers User[] @relation("UserUpdatedBy")
  deletedUsers User[] @relation("UserDeletedBy")

  roles            UserRole[]
  sessions         Session[]
  refreshTokens    RefreshToken[]
  passwordResets   PasswordResetToken[]
  auditLogs         AuditLog[]         @relation("AuditLogActor")
  notifications     Notification[]
  propertiesCreated Property[]         @relation("PropertyCreatedBy")
  propertiesUpdated Property[]         @relation("PropertyUpdatedBy")
  projectsCreated   Project[]          @relation("ProjectCreatedBy")
  projectsUpdated   Project[]          @relation("ProjectUpdatedBy")
  unitsCreated      Unit[]             @relation("UnitCreatedBy")
  unitsUpdated      Unit[]             @relation("UnitUpdatedBy")
  pagesCreated      Page[]             @relation("PageCreatedBy")
  pagesUpdated      Page[]             @relation("PageUpdatedBy")
  templatesCreated  Template[]         @relation("TemplateCreatedBy")
  templatesUpdated  Template[]         @relation("TemplateUpdatedBy")
  mediaUploaded     MediaAsset[]       @relation("MediaUploadedBy")
  roleCreatedRoles          Role[]              @relation("RoleCreatedBy")
  roleUpdatedRoles          Role[]              @relation("RoleUpdatedBy")
  propertyCategoriesCreated PropertyCategory[]  @relation("PropertyCategoryCreatedBy")
  propertyCategoriesUpdated PropertyCategory[]  @relation("PropertyCategoryUpdatedBy")
  mediaFoldersCreated       MediaFolder[]        @relation("MediaFolderCreatedBy")
  mediaFoldersUpdated       MediaFolder[]        @relation("MediaFolderUpdatedBy")
  leadsCreated              Lead[]              @relation("LeadCreatedBy")
  leadsUpdated              Lead[]              @relation("LeadUpdatedBy")
  inquiriesCreated          Inquiry[]           @relation("InquiryCreatedBy")
  inquiriesUpdated          Inquiry[]           @relation("InquiryUpdatedBy")
  leadPipelineStagesCreated  LeadPipelineStage[] @relation("LeadPipelineStageCreatedBy")
  leadPipelineStagesUpdated  LeadPipelineStage[] @relation("LeadPipelineStageUpdatedBy")
  pageSectionsCreated       PageSection[]       @relation("PageSectionCreatedBy")
  pageSectionsUpdated       PageSection[]       @relation("PageSectionUpdatedBy")
  pageWidgetsCreated        PageWidget[]        @relation("PageWidgetCreatedBy")
  pageWidgetsUpdated        PageWidget[]        @relation("PageWidgetUpdatedBy")
  visualPagesCreated        VisualPage[]        @relation("VisualPageCreatedBy")
  visualPagesUpdated        VisualPage[]        @relation("VisualPageUpdatedBy")
  builderAssetsCreated      BuilderAsset[]      @relation("BuilderAssetCreatedBy")
  builderAssetsUpdated      BuilderAsset[]      @relation("BuilderAssetUpdatedBy")
  blogPostsCreated          BlogPost[]          @relation("BlogPostCreatedBy")
  blogPostsUpdated          BlogPost[]          @relation("BlogPostUpdatedBy")

  @@index([status])
  @@index([isActive])
  @@index([deletedAt])
}

model Role {
  id          String           @id @default(cuid())
  name        String           @unique
  nameAr      String
  nameEn      String
  descriptionAr String?
  descriptionEn String?
  isSystem    Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?

  createdById String?
  updatedById String?

  createdBy User? @relation("RoleCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User? @relation("RoleUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  permissions RolePermission[]
  users       UserRole[]

  @@index([deletedAt])
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique
  nameAr      String
  nameEn      String
  module      String
  description String?
  group       String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?
  roles       RolePermission[]

  @@index([module])
  @@index([deletedAt])
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([roleId])
}

model RolePermission {
  id           String   @id @default(cuid())
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([permissionId])
}

model PropertyCategory {
  id          String   @id @default(cuid())
  slug        String   @unique
  nameAr      String
  nameEn      String
  descriptionAr String?
  descriptionEn String?
  parentId    String?
  parent      PropertyCategory? @relation("PropertyCategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    PropertyCategory[] @relation("PropertyCategoryHierarchy")
  properties  Property[]
  projects    Project[]
  units       Unit[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  createdById String?
  updatedById String?
  createdBy   User? @relation("PropertyCategoryCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy   User? @relation("PropertyCategoryUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([parentId])
  @@index([deletedAt])
}

model PropertyFeature {
  id          String   @id @default(cuid())
  key         String   @unique
  nameAr      String
  nameEn      String
  icon        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
  properties  PropertyFeatureOnProperty[]
  units       PropertyFeatureOnUnit[]
  @@index([deletedAt])
}

model Amenity {
  id          String   @id @default(cuid())
  key         String   @unique
  nameAr      String
  nameEn      String
  category    String?
  icon        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
  propertyLinks PropertyAmenity[]
  unitLinks     UnitAmenity[]
  projectLinks  ProjectAmenity[]
  @@index([category])
  @@index([deletedAt])
}

model Project {
  id               String   @id @default(cuid())
  slug             String   @unique
  nameAr           String
  nameEn           String
  descriptionAr    String?
  descriptionEn    String?
  cityAr           String?
  cityEn           String?
  districtAr       String?
  districtEn       String?
  addressAr        String?
  addressEn        String?
  completionDate   DateTime?
  status           String   @default("draft")
  featured         Boolean  @default(false)
  coverMediaId     String?
  seoTitleAr       String?
  seoTitleEn       String?
  seoDescriptionAr String?
  seoDescriptionEn String?
  seoKeywords      String?
  metadata         Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  deletedAt        DateTime?

  createdById String?
  updatedById String?
  createdBy   User? @relation("ProjectCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy   User? @relation("ProjectUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  categoryId String?
  category   PropertyCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  units      Unit[]
  properties Property[]
  amenities  ProjectAmenity[]
  gallery    ProjectMedia[]
  inquiries  Inquiry[]
  leads      Lead[]

  @@index([status])
  @@index([featured])
  @@index([categoryId])
  @@index([deletedAt])
}

model Property {
  id               String   @id @default(cuid())
  slug             String   @unique
  titleAr          String
  titleEn          String
  descriptionAr    String?
  descriptionEn    String?
  price            Decimal  @db.Decimal(18, 2)
  currency         String   @default("SAR")
  status           String   @default("available")
  saleOrRent       String   @default("sale")
  featured         Boolean  @default(false)
  projectId        String?
  categoryId       String?
  featuredMediaId  String?
  seoTitleAr       String?
  seoTitleEn       String?
  seoDescriptionAr String?
  seoDescriptionEn String?
  seoKeywords      String?
  listingDate      DateTime?
  publishedAt      DateTime?
  metadata        Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  deletedAt        DateTime?

  createdById String?
  updatedById String?
  createdBy   User? @relation("PropertyCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy   User? @relation("PropertyUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  project   Project?          @relation(fields: [projectId], references: [id], onDelete: SetNull)
  category  PropertyCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  units     Unit[]
  amenities PropertyAmenity[]
  features  PropertyFeatureOnProperty[]
  media     PropertyMedia[]
  inquiries Inquiry[]
  leads     Lead[]

  @@index([status])
  @@index([saleOrRent])
  @@index([featured])
  @@index([projectId])
  @@index([categoryId])
  @@index([deletedAt])
}

model Unit {
  id              String   @id @default(cuid())
  code            String   @unique
  titleAr         String?
  titleEn         String?
  descriptionAr   String?
  descriptionEn   String?
  propertyId      String?
  projectId       String?
  categoryId      String?
  unitNumber      String?
  floorNumber     Int?
  bedrooms        Int?
  bathrooms       Int?
  areaSqm         Decimal? @db.Decimal(12, 2)
  price           Decimal? @db.Decimal(18, 2)
  currency        String   @default("SAR")
  status          String   @default("available")
  featured        Boolean  @default(false)
  listingDate     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  createdById String?
  updatedById String?
  createdBy   User? @relation("UnitCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy   User? @relation("UnitUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  property  Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  category  PropertyCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  amenities UnitAmenity[]
  features  PropertyFeatureOnUnit[]
  media     UnitMedia[]
  leads     Lead[]    @relation("LeadUnit")
  inquiries Inquiry[] @relation("InquiryUnit")

  @@index([status])
  @@index([propertyId])
  @@index([projectId])
  @@index([categoryId])
  @@index([deletedAt])
}

model PropertyAmenity {
  id         String   @id @default(cuid())
  propertyId String
  amenityId  String
  createdAt  DateTime @default(now())

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  amenity  Amenity  @relation(fields: [amenityId], references: [id], onDelete: Cascade)

  @@unique([propertyId, amenityId])
  @@index([amenityId])
}

model ProjectAmenity {
  id        String   @id @default(cuid())
  projectId String
  amenityId String
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  amenity Amenity @relation(fields: [amenityId], references: [id], onDelete: Cascade)

  @@unique([projectId, amenityId])
  @@index([amenityId])
}

model UnitAmenity {
  id        String   @id @default(cuid())
  unitId    String
  amenityId String
  createdAt DateTime @default(now())

  unit    Unit    @relation(fields: [unitId], references: [id], onDelete: Cascade)
  amenity Amenity @relation(fields: [amenityId], references: [id], onDelete: Cascade)

  @@unique([unitId, amenityId])
  @@index([amenityId])
}

model PropertyFeatureOnProperty {
  id          String   @id @default(cuid())
  propertyId  String
  featureId   String
  createdAt   DateTime @default(now())

  property Property       @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  feature  PropertyFeature @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@unique([propertyId, featureId])
  @@index([featureId])
}

model PropertyFeatureOnUnit {
  id        String   @id @default(cuid())
  unitId    String
  featureId String
  createdAt DateTime @default(now())

  unit    Unit            @relation(fields: [unitId], references: [id], onDelete: Cascade)
  feature PropertyFeature  @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@unique([unitId, featureId])
  @@index([featureId])
}

model MediaAsset {
  id            String      @id @default(cuid())
  originalName  String
  storedName    String
  filePath      String
  publicUrl     String?
  mimeType      String
  extension     String
  category      MediaType   @default(OTHER)
  fileSize      Int
  width         Int?
  height        Int?
  duration      Float?
  altTextAr     String?
  altTextEn     String?
  captionAr     String?
  captionEn     String?
  titleAr       String?
  titleEn       String?
  descriptionAr String?
  descriptionEn String?
  folder        String?
  tags          String[]    @default([])
  dominantColor String?
  isPublic      Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?
  uploadedById  String?
  folderId      String?

  uploadedBy    User?        @relation("MediaUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)
  folderRef     MediaFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  properties PropertyMedia[]
  units      UnitMedia[]
  projects   ProjectMedia[]
  pages      PageMedia[]
  widgets    WidgetMedia[]
  templates  TemplateMedia[]
  settings   SettingMedia[]
  blogPosts  BlogPostMedia[]
  variants   MediaVariant[]

  @@index([category])
  @@index([folderId])
  @@index([uploadedById])
  @@index([deletedAt])
  @@map("Media")
}

model MediaFolder {
  id        String   @id @default(cuid())
  name      String
  path      String   @unique
  slug      String
  parentId  String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  createdById String?
  updatedById String?
  createdBy   User? @relation("MediaFolderCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy   User? @relation("MediaFolderUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  parent MediaFolder? @relation("MediaFolderTree", fields: [parentId], references: [id], onDelete: SetNull)
  children MediaFolder[] @relation("MediaFolderTree")
  media   MediaAsset[]

  @@unique([parentId, name])
  @@index([parentId])
  @@index([deletedAt])
}

model MediaVariant {
  id         String          @id @default(cuid())
  mediaId    String
  variant    MediaVariantType
  filePath   String
  publicUrl  String?
  mimeType   String
  fileSize   Int
  width      Int?
  height     Int?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  deletedAt  DateTime?

  media MediaAsset @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@unique([mediaId, variant])
  @@index([variant])
  @@index([deletedAt])
}

model PropertyMedia {
  id        String @id @default(cuid())
  propertyId String
  mediaId   String
  sortOrder Int    @default(0)
  createdAt DateTime @default(now())

  property Property   @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  media    MediaAsset @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@unique([propertyId, mediaId])
  @@index([mediaId])
}

model ProjectMedia {
  id        String @id @default(cuid())
  projectId String
  mediaId   String
  sortOrder Int    @default(0)
  createdAt DateTime @default(now())

  project Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  media   MediaAsset @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@unique([projectId, mediaId])
  @@index([mediaId])
}

model UnitMedia {
  id       String @id @default(cuid())
  unitId   String
  mediaId  String
  sortOrder Int   @default(0)
  createdAt DateTime @default(now())

  unit  Unit       @relation(fields: [unitId], references: [id], onDelete: Cascade)
  media MediaAsset @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@unique([unitId, mediaId])
  @@index([mediaId])
}

model PageMedia {
  id       String @id @default(cuid())
  pageId   String
  mediaId  String
  sortOrder Int   @default(0)
  createdAt DateTime @default(now())

  page  Page       @relation(fields: [pageId], references: [id], onDelete: Cascade)
  media MediaAsset @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@unique([pageId, mediaId])
  @@index([mediaId])
}

model WidgetMedia {
  id       String @id @default(cuid())
  widgetId String
  mediaId  String
  pageWidgetId String?
  createdAt DateTime @default(now())

  widget Widget     @relation(fields: [widgetId], references: [id], onDelete: Cascade)
  pageWidget PageWidget? @relation(fields: [pageWidgetId], references: [id], onDelete: Cascade)
  media  MediaAsset @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@unique([widgetId, mediaId])
  @@index([pageWidgetId])
  @@index([mediaId])
}

model TemplateMedia {
  id         String @id @default(cuid())
  templateId String
  mediaId    String
  createdAt  DateTime @default(now())

  template Template   @relation(fields: [templateId], references: [id], onDelete: Cascade)
  media    MediaAsset @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@unique([templateId, mediaId])
  @@index([mediaId])
}

model SettingMedia {
  id        String @id @default(cuid())
  settingId String
  mediaId   String
  createdAt DateTime @default(now())

  setting Setting    @relation(fields: [settingId], references: [id], onDelete: Cascade)
  media   MediaAsset @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@unique([settingId, mediaId])
  @@index([mediaId])
}

model BlogPostMedia {
  id         String @id @default(cuid())
  blogPostId String
  mediaId    String
  createdAt  DateTime @default(now())

  blogPost BlogPost  @relation(fields: [blogPostId], references: [id], onDelete: Cascade)
  media    MediaAsset @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@unique([blogPostId, mediaId])
  @@index([mediaId])
}

model Lead {
  id            String      @id @default(cuid())
  fullName      String
  email         String?
  phone         String?
  source        String?
  status        LeadStatus  @default(NEW)
  crmStage      String      @default("new")
  stageId       String?
  notesAr       String?
  notesEn       String?
  propertyId    String?
  projectId     String?
  unitId        String?
  assignedToId   String?
  lastContactAt  DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?

  createdById String?
  updatedById String?
  createdBy   User? @relation("LeadCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy   User? @relation("LeadUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  stage    LeadPipelineStage? @relation(fields: [stageId], references: [id], onDelete: SetNull)
  property Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  project  Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  unit     Unit?     @relation("LeadUnit", fields: [unitId], references: [id], onDelete: SetNull)
  inquiries Inquiry[]
  activities LeadActivity[]

  @@index([status])
  @@index([crmStage])
  @@index([stageId])
  @@index([propertyId])
  @@index([projectId])
  @@index([unitId])
  @@index([deletedAt])
}

model Inquiry {
  id           String         @id @default(cuid())
  fullName     String
  email        String?
  phone        String?
  messageAr    String?
  messageEn    String?
  status       InquiryStatus  @default(NEW)
  propertyId   String?
  projectId    String?
  unitId       String?
  leadId       String?
  source       String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  deletedAt    DateTime?

  createdById String?
  updatedById String?
  createdBy   User? @relation("InquiryCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy   User? @relation("InquiryUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  property Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  project  Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  unit     Unit?     @relation("InquiryUnit", fields: [unitId], references: [id], onDelete: SetNull)
  lead     Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([propertyId])
  @@index([projectId])
  @@index([unitId])
  @@index([leadId])
  @@index([deletedAt])
}

model LeadPipelineStage {
  id          String   @id @default(cuid())
  nameAr      String
  nameEn      String
  slug        String   @unique
  sortOrder   Int      @default(0)
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  createdById String?
  updatedById String?
  createdBy   User? @relation("LeadPipelineStageCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy   User? @relation("LeadPipelineStageUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  leads Lead[]
  activities LeadActivity[]

  @@index([sortOrder])
  @@index([deletedAt])
}

model LeadActivity {
  id          String   @id @default(cuid())
  leadId      String
  stageId     String?
  titleAr     String
  titleEn     String
  descriptionAr String?
  descriptionEn String?
  activityAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lead  Lead              @relation(fields: [leadId], references: [id], onDelete: Cascade)
  stage LeadPipelineStage? @relation(fields: [stageId], references: [id], onDelete: SetNull)

  @@index([leadId])
  @@index([stageId])
}

model Page {
  id           String      @id @default(cuid())
  slug         String      @unique
  titleAr      String
  titleEn      String
  subtitleAr   String?
  subtitleEn   String?
  contentAr    String?
  contentEn    String?
  seoTitleAr   String?
  seoTitleEn   String?
  seoDescriptionAr String?
  seoDescriptionEn String?
  status       PageStatus  @default(DRAFT)
  parentId     String?
  metadata     Json?
  sortOrder    Int         @default(0)
  publishedAt  DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  deletedAt    DateTime?

  createdById String?
  updatedById String?
  createdBy   User? @relation("PageCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy   User? @relation("PageUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  parent   Page?   @relation("PageHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children Page[]  @relation("PageHierarchy")
  sections PageSection[]
  media    PageMedia[]
  templates Template[]
